{
    "name": "@exfolia/api",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "description": "Fastify API for Exfolia.",
    "scripts": {
        "dev": "tsx watch src/server.ts",
        "build": "tsc -p tsconfig.json",
        "start": "node dist/server.js",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "lint": "echo \"api lint setup coming soon\"",
        "test": "vitest run",
        "test:unit": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@fastify/cors": "^10.0.1",
        "dotenv": "^16.4.7",
        "fastify": "^5.2.1",
        "zod": "^3.24.1"
    },
    "devDependencies": {
        "@types/node": "^22.10.5",
        "tsx": "^4.19.2",
        "typescript": "^5.7.2",
        "vitest": "^2.1.8"
    }
}