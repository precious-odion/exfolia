{
    "name": "exfolia",
    "version": "0.1.0",
    "private": true,
    "description": "An AI-powered data exploration workspace for uploading CSV datasets, building visual queries, generating dashboards, and receiving AI-assisted insights.",
    "scripts": {
        "dev:web": "pnpm --filter @exfolia/web dev",
        "dev:api": "pnpm --filter @exfolia/api dev",
        "build": "pnpm -r --if-present build",
        "lint": "pnpm -r --if-present lint",
        "format:check": "echo \"format check setup coming soon\"",
        "typecheck": "pnpm -r --if-present typecheck",
        "test": "pnpm run test:unit && pnpm run test:integration",
        "test:unit": "pnpm -r --if-present test:unit",
        "test:integration": "echo \"integration test setup coming soon\"",
        "test:e2e": "echo \"e2e test setup coming soon\"",
        "ci": "pnpm run lint && pnpm run format:check && pnpm run typecheck && pnpm run test:unit && pnpm run test:integration && pnpm run build",
        "db:up": "docker compose up -d postgres",
        "db:down": "docker compose down",
        "db:logs": "docker compose logs -f postgres",
        "db:ps": "docker compose ps",
        "db:reset": "docker compose down -v && docker compose up -d postgres",
        "db:migrate": "pnpm --filter @exfolia/api db:migrate",
        "db:rollback": "pnpm --filter @exfolia/api db:rollback",
        "db:status": "pnpm --filter @exfolia/api db:status"
    },
    "keywords": [
        "analytics",
        "csv",
        "dashboard",
        "query-builder",
        "data-visualization",
        "ai"
    ],
    "author": "Precious Odion",
    "license": "MIT",
    "packageManager": "pnpm@10.23.0"
}