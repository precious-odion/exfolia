# App
NODE_ENV=development

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000

# Backend
API_PORT=4000
FRONTEND_URL=http://localhost:3000

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=exfolia_dev
POSTGRES_TEST_DB=exfolia_test
POSTGRES_USER=exfolia
POSTGRES_PASSWORD=exfolia_password

# Database URLs
DATABASE_URL=postgresql://exfolia:exfolia_password@localhost:5432/exfolia_dev
TEST_DATABASE_URL=postgresql://exfolia:exfolia_password@localhost:5432/exfolia_test

# AI provider
AI_PROVIDER=gemini
GEMINI_API_KEY=
GROQ_API_KEY=