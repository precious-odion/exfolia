{
    "name": "@exfolia/shared",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "description": "Shared TypeScript contracts and Zod schemas for Exfolia.",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "lint": "echo \"shared lint setup coming soon\"",
        "test": "vitest run",
        "test:unit": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "zod": "^3.24.1"
    },
    "devDependencies": {
        "typescript": "^5.7.2",
        "vitest": "^2.1.8"
    }
}